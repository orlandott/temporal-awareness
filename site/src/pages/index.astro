---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  BASE,
  ISSUES_URL,
  GOOD_FIRST_ISSUES_URL,
  RESULTS_URL,
  CONTRIBUTING_URL,
  RESEARCH_PROGRAM_URL,
} from "../lib/site";

const findings = [
  {
    big: "92.5%",
    lead: "We can read it.",
    body: "In a small AI, we can tell whether it's leaning short-term or long-term just by looking inside it — right about nine times out of ten.",
    tag: "",
  },
  {
    big: "99.2%",
    lead: "Even in bigger models.",
    body: "In a larger, modern AI we can read that sense of time almost perfectly — even after removing every time-related word from the text.",
    tag: "",
  },
  {
    big: "~4×",
    lead: "We can nudge it.",
    body: "Gently adjusting that inner signal makes the AI several times more likely to favour patient, long-term answers.",
    tag: "early",
  },
  {
    big: "Early warning",
    lead: "Why it matters.",
    body: "An AI's safety habits can quietly fade over long, repetitive sessions. Reading this signal could warn us before anything goes wrong in what it says.",
    tag: "",
  },
];

const done = [
  {
    title: "We learned to read an AI's sense of time",
    body: "Working with a small, well-studied AI, we showed that its short- versus long-term leaning can be read straight from inside it — and even gently adjusted.",
  },
  {
    title: "We checked it on bigger, modern models",
    body: "A team of eleven researchers found the same idea holds in today's larger AIs, like Qwen and Llama — not only the small one we started with.",
  },
  {
    title: "We started watching safety “drift”",
    body: "A larger study looked at how an AI's good behaviour can weaken over long, repetitive conversations — and which kinds of models hold up best.",
  },
  {
    title: "We built open tools for everyone",
    body: "A free toolkit lets anyone create tests, read the signal, and explore its “shape” in an interactive viewer.",
  },
  {
    title: "We made it easy to join",
    body: "Every task is a plain GitHub issue. No PhD, no expensive computer, and no special background needed to help.",
  },
];

const missing = [
  {
    h: "We need more examples",
    body: "Some of our most exciting hints rest on only a handful of cases. We need many more before we can be sure.",
  },
  {
    h: "Mostly shown on one small model",
    body: "Our clearest results come from one small, older AI. We're still confirming they hold across today's bigger ones.",
  },
  {
    h: "Are we measuring the real thing?",
    body: "In one test a simple shortcut did just as well as our method — a reminder to keep checking we're reading real understanding, not a trick.",
  },
  {
    h: "Nudging is still hit-or-miss",
    body: "Steering an AI's sense of time works only about 60% of the time so far — promising, but not yet reliable.",
  },
  {
    h: "A lot is built but unfinished",
    body: "Many experiments are set up but haven't been fully run, and some safety tests didn't finish.",
  },
  {
    h: "Newer tools, not yet applied",
    body: "Some of the most promising new techniques are ready in principle but haven't been pointed at the time question yet.",
  },
  {
    h: "Big-model questions remain",
    body: "We haven't yet seen real long-range “planning” in the models small enough for us to study affordably.",
  },
  {
    h: "Some data is still missing",
    body: "A couple of key datasets aren't in the public project yet — a concrete, friendly place to start helping.",
  },
];
---

<BaseLayout title="Temporal Awareness">
  <!-- Hero -->
  <section class="ombre-wash">
    <div class="mx-auto max-w-3xl px-4 pb-14 pt-16 text-center">
      <p class="kicker-accent">An Open Safety Project</p>
      <h1 class="font-display mt-4 text-4xl font-bold leading-[1.1] text-ink sm:text-5xl">
        Can we tell what an AI is thinking about <span class="text-ombre">time</span>?
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-8 text-ink-soft">
        AIs quietly weigh “now” against “later” all the time. We're learning to read that inner
        sense of time directly — and to catch it when it drifts, before it ever shows up in what
        the AI says.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3 font-sans text-sm font-semibold">
        <a href={`${BASE}understand`} class="btn-ombre rounded-full px-6 py-3 shadow-sm transition hover:opacity-90">
          Start with the idea →
        </a>
        <a href={GOOD_FIRST_ISSUES_URL} class="rounded-full border border-ink/20 px-6 py-3 text-ink transition hover:border-accent-500 hover:text-accent-700">
          Help out
        </a>
      </div>
    </div>
  </section>

  <!-- Plain-language explainer -->
  <article class="mx-auto max-w-2xl px-4 py-12">
    <p class="dropcap text-lg leading-8 text-ink-soft">
      Every day, AI systems make choices that play out over time — answer right now or think a
      little longer, help with this one reply or look after the whole conversation.
      <strong class="text-ink">Temporal awareness</strong> is simply how an AI leans in those
      moments: toward the quick payoff, or the patient one.
    </p>
    <p class="mt-5 text-lg leading-8 text-ink-soft">
      Here's the catch that makes it a safety question: an AI's words and its inner leanings don't
      always match. It can <em>say</em> something careful and short-term while, inside, it's set on
      a longer game — or the other way around. As AIs are trusted to run on their own for longer
      stretches, that hidden drift is exactly what we'd like to notice early.
    </p>
    <p class="mt-5 text-lg leading-8 text-ink-soft">
      The encouraging news: this inner sense of time turns out to be
      <strong class="text-ink">surprisingly easy to read</strong> from inside the model. If that
      holds up, a small, cheap “detector” could watch for trouble in real time — a practical safety
      tool, not just a worry.
    </p>
    <p class="mt-5 text-lg leading-8 text-ink-soft">
      What follows is an honest scorecard: what we're fairly sure of, and the much longer list of
      what we still don't know.
    </p>
  </article>

  <!-- What we've found -->
  <section class="border-t border-rule">
    <div class="mx-auto max-w-4xl px-4 py-12">
      <p class="kicker-accent">What we've found</p>
      <h2 class="font-display mt-2 text-3xl font-bold text-ink">The story so far, in plain terms</h2>
      <hr class="rule-ombre mt-3 w-28" />
      <div class="mt-8 grid gap-5 sm:grid-cols-2">
        {
          findings.map((f) => (
            <div class="rounded-2xl border border-rule bg-white/70 p-6">
              <div class="font-display text-3xl font-bold text-ombre">{f.big}</div>
              <div class="mt-2 font-semibold text-ink">{f.lead}</div>
              <p class="mt-1.5 leading-7 text-ink-soft">{f.body}</p>
              {f.tag === "early" && (
                <span class="mt-3 inline-block font-sans text-xs uppercase tracking-wide text-accent-700">
                  ◦ early result
                </span>
              )}
            </div>
          ))
        }
      </div>
      <p class="mt-4 text-sm text-ink-soft">
        Want the exact numbers and the methods behind them?{" "}
        <a class="link-accent" href={`${BASE}what-we-score`}>See the full breakdown →</a>
      </p>
    </div>
  </section>

  <!-- What we've done -->
  <section class="mx-auto max-w-4xl px-4 py-12">
    <p class="kicker-accent">What we've done</p>
    <h2 class="font-display mt-2 text-3xl font-bold text-ink">Real progress, so far</h2>
    <div class="mt-8 space-y-7">
      {
        done.map((item, i) => (
          <div class="flex gap-5">
            <div class="font-display text-2xl font-bold text-ombre">{String(i + 1).padStart(2, "0")}</div>
            <div>
              <h3 class="font-display text-xl font-bold text-ink">{item.title}</h3>
              <p class="mt-1 leading-7 text-ink-soft">{item.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- What's missing -->
  <section class="ombre-soft border-y border-rule">
    <div class="mx-auto max-w-4xl px-4 py-12">
      <p class="kicker-accent">What's missing</p>
      <h2 class="font-display mt-2 text-3xl font-bold text-ink">And what we still don't know</h2>
      <p class="mt-3 max-w-2xl text-lg leading-8 text-ink-soft">
        A safety project should be upfront about its limits. Here's what these results
        <em>don't</em> prove yet — and where you could help.
      </p>
      <div class="mt-8 grid gap-x-10 gap-y-6 md:grid-cols-2">
        {
          missing.map((item) => (
            <div>
              <h3 class="font-display text-lg font-bold text-ink">{item.h}</h3>
              <p class="mt-1 leading-7 text-ink-soft">{item.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Contribute -->
  <section class="mx-auto max-w-3xl px-4 py-14 text-center">
    <p class="kicker-accent">Join in</p>
    <h2 class="font-display mt-2 text-3xl font-bold text-ink">You can help — really</h2>
    <p class="mx-auto mt-3 max-w-xl text-lg leading-8 text-ink-soft">
      No PhD, no fancy hardware, and no background in AI safety required. Every task is a friendly
      GitHub issue. Pick one and dive in.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3 font-sans text-sm font-semibold">
      <a href={GOOD_FIRST_ISSUES_URL} class="btn-ombre rounded-full px-6 py-3 shadow-sm transition hover:opacity-90">
        Find a beginner-friendly task
      </a>
      <a href={`${BASE}understand`} class="rounded-full border border-ink/20 px-6 py-3 text-ink transition hover:border-accent-500 hover:text-accent-700">
        Read the intro
      </a>
    </div>
    <p class="mt-6 font-sans text-xs uppercase tracking-widest text-ink-soft">
      <a class="hover:text-ink" href={ISSUES_URL}>All tasks</a> ·
      <a class="hover:text-ink" href={CONTRIBUTING_URL}>Contributor guide</a> ·
      <a class="hover:text-ink" href={RESEARCH_PROGRAM_URL}>Research program</a> ·
      <a class="hover:text-ink" href={RESULTS_URL}>Results</a>
    </p>
  </section>
</BaseLayout>
